generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATIONS_MANAGER
  MODERATOR
  PRODUCTION_STAFF
  FINANCE_STAFF
  SUPPORT_STAFF
  DESIGNER
  CUSTOMER
  CORPORATE_CLIENT
}

enum DesignerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum DesignStatus {
  DRAFT
  PENDING_MODERATION
  SUBMITTED
  NEEDS_FIX
  APPROVED_LOCAL
  APPROVED_GLOBAL
  APPROVED
  REJECTED
  SUSPENDED
  READY_FOR_MOCKUP
  READY_TO_PUBLISH
  PUBLISHED
}

enum ModerationDecision {
  APPROVE
  REJECT
  REQUEST_CHANGES
  SUSPEND
}

enum GeneratedAssetStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum WorkerJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ListingType {
  PRODUCT
  FILM
}

enum ListingStatus {
  DRAFT
  READY_FOR_REVIEW
  READY_TO_PUBLISH
  PUBLISHED
  UNPUBLISHED
  FAILED
  ARCHIVED
  REJECTED
  SUSPENDED
}

enum PipelineType {
  LOCAL
  GLOBAL_PRINTFUL
}

enum ProviderType {
  RASHPOD
  PRINTFUL
  DIRECT_MARKETPLACE
}

enum ModerationPipelineDecision {
  REJECT
  APPROVE_LOCAL
  APPROVE_GLOBAL
}

enum RejectionReasonCode {
  COPYRIGHT_RISK
  OFFENSIVE_CONTENT
  POLITICAL_SENSITIVE_CONTENT
  LOW_IMAGE_RESOLUTION
  POOR_IMAGE_QUALITY
  WRONG_FILE_FORMAT
  TRANSPARENCY_OR_BACKGROUND_ISSUE
  NOT_SUITABLE_FOR_PRODUCTION
  DUPLICATE_OR_SPAM
  MARKETPLACE_COMPLIANCE_RISK
  OTHER
}

enum LocalProductType {
  T_SHIRT
  LONG_SLEEVE_T_SHIRT
  HOODIE
  SWEATSHIRT
  MUG
  CAP
  TOTE_BAG
  POSTER
  STICKER
  DTF_FILM
  UV_DTF_FILM
  OTHER
}

enum NecklineType {
  CREW_NECK
  V_NECK
  POLO
  HOODIE
  NONE
}

enum SleeveType {
  SHORT
  LONG
  SLEEVELESS
  NONE
}

enum LocalProductionMethod {
  DTF
  UV_DTF
  DTG
  SUBLIMATION
  EMBROIDERY
  OTHER
}

enum PlacementKind {
  FRONT
  BACK
  LEFT_CHEST
  RIGHT_CHEST
  LEFT_SLEEVE
  RIGHT_SLEEVE
  FULL_WRAP
  OTHER
}

enum PlacementAlignment {
  CENTER
  TOP_CENTER
  LEFT_CHEST
  CUSTOM
}

enum PlacementUnits {
  CM
  INCH
  PX
}

enum DesignProductSelectionStatus {
  SELECTED
  MOCKUP_PENDING
  MOCKUP_GENERATING
  MOCKUP_READY
  MOCKUP_FAILED
  LISTING_DRAFT
  READY_TO_PUBLISH
  PUBLISHED
  FAILED
}

enum MockupAssetType {
  MAIN
  SECONDARY
  DETAIL
  LIFESTYLE
  PRINT_AREA_PREVIEW
}

enum MockupAssetStatus {
  PENDING
  GENERATED
  FAILED
}

enum MarketplaceKind {
  RASHPOD_LOCAL
  LOCAL_MARKETPLACE
  ETSY
  AMAZON
  EBAY
  SHOPIFY
  WOOCOMMERCE
}

enum MarketplacePublicationStatus {
  NOT_SELECTED
  DRAFT
  QUEUED
  PUBLISHING
  PUBLISHED
  FAILED
  NEEDS_REVIEW
}

enum PrintfulMappingStatus {
  PENDING
  READY
  FAILED
}

enum IntegrationLogStatus {
  PENDING
  SUCCESS
  FAILED
  SKIPPED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  IN_PRODUCTION
  READY_FOR_PICKUP
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ProductionJobStatus {
  ORDERED
  FILE_CHECK
  READY_FOR_PRINT
  PRINTING
  QC
  PACKING
  READY_FOR_PICKUP
  DELIVERED
}

enum CorporateRequestStatus {
  OPEN
  IN_REVIEW
  BIDDING
  OFFER_PENDING
  ACCEPTED
  REJECTED
}

enum DesignerBidStatus {
  SUBMITTED
  SHORTLISTED
  SELECTED
  REJECTED
}

enum CommercialOfferStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum ExchangeRateSource {
  MANUAL
  SYSTEM
}

enum LedgerEntryType {
  SALE
  ROYALTY
  BONUS
  PAYOUT
  ADJUSTMENT
  REFUND
}

enum LedgerEntryStatus {
  PENDING
  POSTED
  VOID
}

enum RoyaltyLedgerStatus {
  CALCULATED
  ACKNOWLEDGED
  PAIDOUT
  CANCELLED
}

enum PayoutStatus {
  REQUESTED
  PROCESSING
  CONFIRMED
  FAILED
  CANCELLED
}

enum PayoutMethod {
  CLICK_WALLET
  BANK_ACCOUNT
  MANUAL
}

enum BonusType {
  MANUAL
  GROUP
  PERFORMANCE
  CAMPAIGN
}

enum BonusStatus {
  DRAFT
  APPLIED
  CANCELLED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  displayName  String
  bio          String?
  avatarUrl    String?
  coverUrl     String?
  handle       String?  @unique
  socialLinks  Json?
  role         UserRole
  designerStatus DesignerStatus @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  designAssets DesignAsset[]
  auditLogs    AuditLog[]
  moderationCases DesignModerationCase[] @relation("ReviewerCases")
  listings     CommerceListing[] @relation("ListingDesigner")
  orders       Order[] @relation("CustomerOrders")
  corporateRequests CorporateRequest[] @relation("CorporateClientRequests")
  designerBids DesignerBid[] @relation("BidDesigner")
  preferences  UserPreferences?
  ledgerEntries LedgerEntry[] @relation("DesignerLedgerEntries")
  royaltyLedgerEntries RoyaltyLedgerEntry[] @relation("DesignerRoyaltyLedgerEntries")
  payouts      Payout[] @relation("DesignerPayouts")
  bonuses      DesignerBonus[] @relation("DesignerBonuses")
  createdBonuses DesignerBonus[] @relation("BonusCreator")
  createdGroupBonuses GroupBonus[] @relation("GroupBonusCreator")
}

model UserPreferences {
  id                 String   @id @default(uuid())
  userId             String   @unique
  portfolioJson      Json?
  payoutDetailsJson  Json?
  notificationJson   Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DesignAsset {
  id          String       @id @default(uuid())
  designerId  String
  title       String
  description String?
  tags        Json?
  categoryId  String?
  originalFileUrl String?
  processedFileUrl String?
  transparentFileUrl String?
  previewUrl  String?
  widthPx     Int?
  heightPx    Int?
  dpi         Int?
  fileType    String?
  fileSize    Int?
  status      DesignStatus @default(DRAFT)
  moderationDecision String?
  moderationStatus String?
  moderatedById String?
  moderatedAt DateTime?
  rejectionReasons Json?
  customRejectionReason String?
  copyrightRiskStatus String?
  contentSafetyStatus String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  designer         User              @relation(fields: [designerId], references: [id])
  versions         DesignVersion[]
  commercialRights CommercialRights?
  moderationCases  DesignModerationCase[]
  moderationAudits ModerationAudit[]
  placements       MockupPlacement[]
  productSelections DesignProductSelection[]
  mockupAssets     MockupAsset[]
  printfulFileMappings PrintfulFileMapping[]
  listings         CommerceListing[]
}

model DesignVersion {
  id            String   @id @default(uuid())
  designAssetId String
  fileKey       String
  widthPx       Int?
  heightPx      Int?
  dpi           Int?
  hasTransparency Boolean?
  createdAt     DateTime @default(now())

  designAsset DesignAsset @relation(fields: [designAssetId], references: [id])
  moderationCases DesignModerationCase[]
  placements      MockupPlacement[]
}

model DesignModerationCase {
  id              String             @id @default(uuid())
  designAssetId   String
  designVersionId String?
  reviewerId      String?
  decision        ModerationDecision
  reason          String?
  createdAt       DateTime           @default(now())

  designAsset   DesignAsset   @relation(fields: [designAssetId], references: [id])
  designVersion DesignVersion? @relation(fields: [designVersionId], references: [id])
  reviewer      User?         @relation("ReviewerCases", fields: [reviewerId], references: [id])
}

model ModerationAudit {
  id              String                     @id @default(uuid())
  designId        String
  moderatorId     String
  decision        ModerationPipelineDecision
  predefinedReasons Json?
  customReason    String?
  notes           String?
  beforeStatus    DesignStatus
  afterStatus     DesignStatus
  createdAt       DateTime                   @default(now())

  design DesignAsset @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@index([designId, createdAt])
  @@index([moderatorId])
}

model FileAsset {
  id           String   @id @default(uuid())
  ownerId      String
  bucket       String
  objectKey    String   @unique
  mimeType     String
  sizeBytes    Int
  isPublic     Boolean  @default(false)
  uploadStatus String
  checksum     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CommercialRights {
  id                         String    @id @default(uuid())
  designAssetId              String    @unique
  allowProductSales          Boolean   @default(false)
  allowMarketplacePublishing Boolean   @default(false)
  allowFilmSales             Boolean   @default(false)
  allowCorporateBidding      Boolean   @default(false)
  filmConsentGrantedAt       DateTime?
  filmConsentRevokedAt       DateTime?
  filmConsentVersionId       String?
  filmRoyaltyRate            Float?
  updatedAt                  DateTime  @updatedAt

  designAsset DesignAsset @relation(fields: [designAssetId], references: [id])
}

model ProductType {
  id                     String   @id @default(uuid())
  name                   String
  slug                   String   @unique
  category               String
  isActive               Boolean  @default(true)
  availableForDesigners  Boolean  @default(true)
  availableInShop        Boolean  @default(true)
  availableForCorporate  Boolean  @default(true)
  availableForMarketplace Boolean @default(false)
  requiresMockup         Boolean  @default(true)
  supportsFilmSale       Boolean  @default(false)
  productionMethod       String
  baseCost               Decimal? @db.Decimal(10, 2)
  defaultMargin          Decimal? @db.Decimal(10, 2)
  metadataJson           Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  baseProducts           BaseProduct[]
}

model RoyaltyRule {
  id          String   @id @default(uuid())
  scope       String
  basis       String
  value       Decimal  @db.Decimal(10, 4)
  isActive    Boolean  @default(true)
  effectiveAt DateTime
  metadataJson Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  royaltyLedgerEntries RoyaltyLedgerEntry[]
}

model BaseProduct {
  id              String   @id @default(uuid())
  productTypeId   String
  name            String
  slug            String?
  localProductType LocalProductType?
  neckline        NecklineType?
  sleeveType      SleeveType?
  skuPrefix       String
  isActive        Boolean  @default(true)
  baseCost        Decimal? @db.Decimal(10, 2)
  defaultPrice    Decimal? @db.Decimal(10, 2)
  currency        String   @default("UZS")
  imageUrl        String?
  description     String?
  baseImageUrls   Json?
  mockupSceneImages Json?
  printableAreas  Json?
  availableColors Json?
  availableSizes  Json?
  localProductionMethod LocalProductionMethod?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  productType     ProductType      @relation(fields: [productTypeId], references: [id], onDelete: Restrict)
  mockupTemplates MockupTemplate[]
  placementPresets PlacementPreset[]
  productSelections DesignProductSelection[]
  listings CommerceListing[]
}

model MockupTemplate {
  id               String   @id @default(uuid())
  baseProductId    String
  name             String
  baseImageKey     String
  lifestyleImageKey String?
  closeupImageKey  String?
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  baseProduct BaseProduct @relation(fields: [baseProductId], references: [id])
  printAreas  PrintArea[]
  placements  MockupPlacement[]
}

model PrintArea {
  id               String   @id @default(uuid())
  mockupTemplateId String
  name             String
  placement        PlacementKind?
  widthCm          Float?
  heightCm         Float?
  x                Int
  y                Int
  width            Int
  height           Int
  safeZonePx       Int?
  defaultPresetId  String?
  isActive         Boolean @default(true)
  safeX            Int
  safeY            Int
  safeWidth        Int
  safeHeight       Int
  allowMove        Boolean  @default(true)
  allowResize      Boolean  @default(true)
  allowRotate      Boolean  @default(false)
  minScale         Float    @default(0.1)
  maxScale         Float    @default(2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  mockupTemplate MockupTemplate @relation(fields: [mockupTemplateId], references: [id])
  placements     MockupPlacement[]
}

model PrintfulProductTemplate {
  id                       String       @id @default(uuid())
  rashpodProductType        String
  displayName               String
  provider                  ProviderType @default(PRINTFUL)
  printfulCatalogProductId  String
  printfulProductName       String
  printfulVariantIds        Json
  allowedColorVariantIds    Json?
  allowedSizeVariantIds     Json?
  allowedPlacements         Json
  allowedTechniques         Json
  defaultTechnique          String
  defaultPlacement          String
  printfulStoreId           String?
  defaultRetailPrice        Decimal? @db.Decimal(10, 2)
  estimatedBaseCost         Decimal? @db.Decimal(10, 2)
  currency                  String   @default("USD")
  active                    Boolean  @default(true)
  metadataJson              Json?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  placementPresets PlacementPreset[]
  productSelections DesignProductSelection[]
  listings CommerceListing[]

  @@unique([provider, printfulCatalogProductId, displayName])
}

model PlacementPreset {
  id                      String             @id @default(uuid())
  name                    String
  pipeline                PipelineType
  productTemplateId       String?
  localBaseProductId      String?
  placement               PlacementKind
  defaultWidthCm          Float?
  defaultHeightCm         Float?
  defaultWidthIn          Float?
  defaultHeightIn         Float?
  defaultX                Float?
  defaultY                Float?
  defaultScale            Float              @default(1)
  alignment               PlacementAlignment @default(CENTER)
  units                   PlacementUnits     @default(CM)
  active                  Boolean            @default(true)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  printfulProductTemplate PrintfulProductTemplate? @relation(fields: [productTemplateId], references: [id])
  localBaseProduct        BaseProduct?             @relation(fields: [localBaseProductId], references: [id])
  productSelections       DesignProductSelection[]

  @@index([pipeline, active])
}

model FilmSaleSettings {
  id                        String   @id @default(uuid())
  enableFilmSalesGlobally   Boolean  @default(false)
  enableDTF                 Boolean  @default(true)
  enableUvDtf               Boolean  @default(true)
  defaultRoyaltyBasis       String
  defaultRoyaltyValue       Decimal  @db.Decimal(10, 4)
  minimumOrderPrice         Decimal? @db.Decimal(10, 2)
  rushOrderFee              Decimal? @db.Decimal(10, 2)
  revocationPolicy          String?
  updatedAt                 DateTime @updatedAt
}

model DeliverySetting {
  id                    String   @id @default(uuid())
  providerType          String
  displayName           String
  isActive              Boolean  @default(true)
  zone                  String
  price                 Decimal? @db.Decimal(10, 2)
  freeDeliveryThreshold Decimal? @db.Decimal(10, 2)
  etaText               String?
  metadataJson          Json?
  updatedAt             DateTime @updatedAt
}

model MockupPlacement {
  id               String   @id @default(uuid())
  designAssetId    String
  designVersionId  String
  mockupTemplateId String
  printAreaId      String
  x                Int
  y                Int
  scale            Float
  rotation         Float    @default(0)
  width            Int
  height           Int
  approvedByDesigner Boolean @default(false)
  approvedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  designAsset    DesignAsset    @relation(fields: [designAssetId], references: [id])
  designVersion  DesignVersion  @relation(fields: [designVersionId], references: [id])
  mockupTemplate MockupTemplate @relation(fields: [mockupTemplateId], references: [id])
  printArea      PrintArea      @relation(fields: [printAreaId], references: [id])
  generatedAssets GeneratedAsset[]
}

model GeneratedAsset {
  id                String               @id @default(uuid())
  sourcePlacementId String
  type              String
  status            GeneratedAssetStatus @default(PENDING)
  fileKey           String?
  widthPx           Int?
  heightPx          Int?
  errorMessage      String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  sourcePlacement MockupPlacement @relation(fields: [sourcePlacementId], references: [id])
}

model DesignProductSelection {
  id                         String                       @id @default(uuid())
  designId                   String
  pipeline                   PipelineType
  localBaseProductId          String?
  printfulProductTemplateId   String?
  placementPresetId           String
  placement                   PlacementKind
  technique                   String?
  width                       Float?
  height                      Float?
  x                           Float?
  y                           Float?
  top                         Float?
  left                        Float?
  scale                       Float                        @default(1)
  rotation                    Float                        @default(0)
  units                       PlacementUnits               @default(CM)
  positionHash                String
  placementConfigJson          Json?
  targetMarketplaces          Json?
  selectedByModeratorId       String
  status                      DesignProductSelectionStatus @default(SELECTED)
  errorMessage                String?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt

  design                  DesignAsset              @relation(fields: [designId], references: [id], onDelete: Cascade)
  localBaseProduct        BaseProduct?             @relation(fields: [localBaseProductId], references: [id])
  printfulProductTemplate PrintfulProductTemplate? @relation(fields: [printfulProductTemplateId], references: [id])
  placementPreset         PlacementPreset          @relation(fields: [placementPresetId], references: [id])
  mockupAssets            MockupAsset[]
  productListing          CommerceListing?

  @@unique([designId, pipeline, positionHash])
  @@index([designId, pipeline])
  @@index([status])
}

model MockupAsset {
  id                       String            @id @default(uuid())
  designId                 String
  designProductSelectionId String
  pipeline                 PipelineType
  provider                 ProviderType
  imageUrl                 String?
  thumbnailUrl             String?
  mockupType               MockupAssetType
  providerMockupId         String?
  providerTaskId           String?
  status                   MockupAssetStatus @default(PENDING)
  metadataJson             Json?
  createdAt                DateTime          @default(now())

  design           DesignAsset            @relation(fields: [designId], references: [id], onDelete: Cascade)
  productSelection DesignProductSelection @relation(fields: [designProductSelectionId], references: [id], onDelete: Cascade)

  @@index([designId, pipeline])
  @@index([designProductSelectionId, status])
}

model CommerceListing {
  id             String       @id @default(uuid())
  type           ListingType
  status         ListingStatus @default(DRAFT)
  designerId     String
  designAssetId  String
  pipeline       PipelineType?
  title          String
  description    String?
  tags           Json?
  categoryId     String?
  productType    String?
  localBaseProductId String?
  printfulProductTemplateId String?
  designProductSelectionId String? @unique
  mockupAssetIds Json?
  slug           String       @unique
  price          Decimal      @db.Decimal(10, 2)
  currency       String       @default("UZS")
  cost           Decimal?     @db.Decimal(10, 2)
  marketplaceFeeEstimate Decimal? @db.Decimal(10, 2)
  rashpodCommission Decimal? @db.Decimal(10, 2)
  designerRoyalty Decimal? @db.Decimal(10, 2)
  seoMetadata    Json?
  imagesJson     Json?
  metadataJson   Json?
  publishedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  designer    User       @relation("ListingDesigner", fields: [designerId], references: [id])
  designAsset DesignAsset @relation(fields: [designAssetId], references: [id])
  localBaseProduct BaseProduct? @relation(fields: [localBaseProductId], references: [id])
  printfulProductTemplate PrintfulProductTemplate? @relation(fields: [printfulProductTemplateId], references: [id])
  designProductSelection DesignProductSelection? @relation(fields: [designProductSelectionId], references: [id])
  marketplacePublications MarketplacePublication[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  royaltyLedgerEntries RoyaltyLedgerEntry[]
}

model MarketplacePublication {
  id                         String                       @id @default(uuid())
  productListingId           String
  marketplace                MarketplaceKind
  provider                   ProviderType
  providerStoreId            String?
  providerSyncProductId      String?
  providerExternalListingId  String?
  status                     MarketplacePublicationStatus @default(DRAFT)
  errorMessage               String?
  lastSyncedAt               DateTime?
  metadataJson               Json?
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt

  productListing CommerceListing @relation(fields: [productListingId], references: [id], onDelete: Cascade)

  @@unique([productListingId, marketplace])
  @@index([marketplace, status])
}

model PrintfulFileMapping {
  id              String                @id @default(uuid())
  designId        String
  printfulFileId  String?
  originalUrl     String?
  printfulUrl     String?
  status          PrintfulMappingStatus @default(PENDING)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  design DesignAsset @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@unique([designId, printfulFileId])
  @@index([designId, status])
}

model IntegrationLog {
  id                         String               @id @default(uuid())
  designId                   String?
  productListingId           String?
  marketplacePublicationId   String?
  action                     String
  requestId                  String?
  status                     IntegrationLogStatus
  errorCode                  String?
  errorMessage               String?
  responseSummaryJson        Json?
  createdAt                  DateTime             @default(now())

  @@index([designId, createdAt])
  @@index([productListingId, createdAt])
  @@index([marketplacePublicationId, createdAt])
  @@index([action, status])
}

model Cart {
  id         String   @id @default(uuid())
  customerId String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  items      CartItem[]
}

model CartItem {
  id         String   @id @default(uuid())
  cartId     String
  listingId  String
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  metadataJson Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cart       Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  listing    CommerceListing @relation(fields: [listingId], references: [id])
}

model Order {
  id            String      @id @default(uuid())
  customerId    String
  status        OrderStatus @default(PENDING_PAYMENT)
  subtotal      Decimal     @db.Decimal(10, 2)
  deliveryFee   Decimal     @db.Decimal(10, 2)
  total         Decimal     @db.Decimal(10, 2)
  currency      String      @default("UZS")
  deliveryType  String?
  deliveryZone  String?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  customer      User                 @relation("CustomerOrders", fields: [customerId], references: [id])
  items         OrderItem[]
  payments      PaymentTransaction[]
  productionJobs ProductionJob[]
  ledgerEntries LedgerEntry[]
  royaltyLedgerEntries RoyaltyLedgerEntry[]
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  listingId   String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  totalPrice  Decimal  @db.Decimal(10, 2)
  metadataJson Json?
  createdAt   DateTime @default(now())

  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listing     CommerceListing @relation(fields: [listingId], references: [id])
  ledgerEntries LedgerEntry[]
  royaltyLedgerEntries RoyaltyLedgerEntry[]
}

model PaymentTransaction {
  id               String        @id @default(uuid())
  orderId           String
  provider          String
  providerRef       String?
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("UZS")
  status            PaymentStatus @default(PENDING)
  rawPayloadJson    Json?
  idempotencyKey    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  order             Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ledgerEntries     LedgerEntry[]
}

model CurrencyConfig {
  code              String   @id
  name              String
  symbol            String
  decimalPlaces     Int      @default(2)
  isActive          Boolean  @default(true)
  isPrimary         Boolean  @default(false)
  exchangeRateToUzs Decimal  @db.Decimal(18, 6)
  metadataJson      Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ExchangeRate {
  id           String             @id @default(uuid())
  fromCurrency String
  toCurrency   String             @default("UZS")
  rate         Decimal            @db.Decimal(18, 6)
  source       ExchangeRateSource @default(MANUAL)
  effectiveAt  DateTime
  createdAt    DateTime           @default(now())

  @@index([fromCurrency, toCurrency, effectiveAt])
}

model LedgerEntry {
  id                   String            @id @default(uuid())
  type                 LedgerEntryType
  status               LedgerEntryStatus @default(POSTED)
  designerId           String?
  orderId              String?
  orderItemId          String?
  paymentTransactionId String?
  amount               Decimal           @db.Decimal(12, 2)
  currency             String            @default("UZS")
  amountUzs            Decimal           @db.Decimal(12, 2)
  description          String?
  metadataJson         Json?
  postedAt             DateTime?
  createdAt            DateTime          @default(now())

  designer           User?               @relation("DesignerLedgerEntries", fields: [designerId], references: [id])
  order              Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderItem          OrderItem?          @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  paymentTransaction PaymentTransaction? @relation(fields: [paymentTransactionId], references: [id], onDelete: SetNull)
  payoutLines        PayoutLedgerEntry[]
  bonus              DesignerBonus?

  @@index([designerId, createdAt])
  @@index([type, status])
}

model RoyaltyLedgerEntry {
  id             String              @id @default(uuid())
  designerId     String
  orderId        String
  orderItemId    String
  listingId      String
  royaltyRuleId  String?
  royaltyRate    Decimal             @db.Decimal(10, 4)
  amount         Decimal             @db.Decimal(12, 2)
  currency       String              @default("UZS")
  amountUzs      Decimal             @db.Decimal(12, 2)
  status         RoyaltyLedgerStatus @default(CALCULATED)
  metadataJson   Json?
  createdAt      DateTime            @default(now())
  acknowledgedAt DateTime?
  paidOutAt      DateTime?
  payoutId       String?

  designer    User            @relation("DesignerRoyaltyLedgerEntries", fields: [designerId], references: [id])
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem   OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  listing     CommerceListing @relation(fields: [listingId], references: [id])
  royaltyRule RoyaltyRule?    @relation(fields: [royaltyRuleId], references: [id], onDelete: SetNull)
  payout      Payout?         @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@unique([orderItemId, designerId])
  @@index([designerId, status])
  @@index([orderId])
}

model Payout {
  id            String       @id @default(uuid())
  designerId    String
  amount        Decimal      @db.Decimal(12, 2)
  currency      String       @default("UZS")
  amountUzs     Decimal      @db.Decimal(12, 2)
  method        PayoutMethod @default(MANUAL)
  status        PayoutStatus @default(REQUESTED)
  reference     String?
  failureReason String?
  metadataJson  Json?
  requestedAt   DateTime     @default(now())
  processingAt  DateTime?
  confirmedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  designer       User                 @relation("DesignerPayouts", fields: [designerId], references: [id])
  royaltyEntries RoyaltyLedgerEntry[]
  ledgerEntries  PayoutLedgerEntry[]

  @@index([designerId, status])
}

model PayoutLedgerEntry {
  id            String   @id @default(uuid())
  payoutId      String
  ledgerEntryId String
  amount        Decimal  @db.Decimal(12, 2)
  currency      String   @default("UZS")
  amountUzs     Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())

  payout      Payout      @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  ledgerEntry LedgerEntry @relation(fields: [ledgerEntryId], references: [id], onDelete: Cascade)

  @@unique([payoutId, ledgerEntryId])
}

model DesignerBonus {
  id            String      @id @default(uuid())
  designerId    String
  groupBonusId  String?
  ledgerEntryId String?     @unique
  createdById   String?
  type          BonusType   @default(MANUAL)
  status        BonusStatus @default(APPLIED)
  amount        Decimal     @db.Decimal(12, 2)
  currency      String      @default("UZS")
  amountUzs     Decimal     @db.Decimal(12, 2)
  reason        String
  metadataJson  Json?
  createdAt     DateTime    @default(now())
  appliedAt     DateTime?
  cancelledAt   DateTime?

  designer    User         @relation("DesignerBonuses", fields: [designerId], references: [id])
  createdBy   User?        @relation("BonusCreator", fields: [createdById], references: [id], onDelete: SetNull)
  groupBonus  GroupBonus?  @relation(fields: [groupBonusId], references: [id], onDelete: SetNull)
  ledgerEntry LedgerEntry? @relation(fields: [ledgerEntryId], references: [id], onDelete: SetNull)

  @@index([designerId, status])
  @@index([groupBonusId])
}

model GroupBonus {
  id                   String      @id @default(uuid())
  name                 String
  type                 BonusType   @default(GROUP)
  status               BonusStatus @default(DRAFT)
  amountPerDesigner    Decimal     @db.Decimal(12, 2)
  currency             String      @default("UZS")
  amountPerDesignerUzs Decimal     @db.Decimal(12, 2)
  reason               String
  criteriaJson         Json?
  createdById          String?
  createdAt            DateTime    @default(now())
  appliedAt            DateTime?
  cancelledAt          DateTime?

  createdBy User?           @relation("GroupBonusCreator", fields: [createdById], references: [id], onDelete: SetNull)
  bonuses   DesignerBonus[]
}

model ProductionJob {
  id           String              @id @default(uuid())
  orderId      String
  orderItemId  String?
  status       ProductionJobStatus @default(ORDERED)
  queueType    String
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model CorporateRequest {
  id            String               @id @default(uuid())
  corporateUserId String
  title         String
  details       String?
  quantity      Int
  budget        Decimal?             @db.Decimal(10, 2)
  deadline      DateTime?
  status        CorporateRequestStatus @default(OPEN)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  corporateUser User         @relation("CorporateClientRequests", fields: [corporateUserId], references: [id])
  bids          DesignerBid[]
  offers        CommercialOffer[]
}

model DesignerBid {
  id            String          @id @default(uuid())
  corporateRequestId String
  designerId    String
  proposal      String
  designFee     Decimal         @db.Decimal(10, 2)
  timelineDays  Int
  status        DesignerBidStatus @default(SUBMITTED)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  corporateRequest CorporateRequest @relation(fields: [corporateRequestId], references: [id], onDelete: Cascade)
  designer         User             @relation("BidDesigner", fields: [designerId], references: [id])
  selectedInOffers CommercialOffer[]
}

model CommercialOffer {
  id            String              @id @default(uuid())
  corporateRequestId String
  selectedBidId String?
  offerNumber   String              @unique
  status        CommercialOfferStatus @default(DRAFT)
  subtotal      Decimal             @db.Decimal(10, 2)
  discount      Decimal             @db.Decimal(10, 2) @default(0)
  total         Decimal             @db.Decimal(10, 2)
  terms         String?
  sentAt        DateTime?
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  corporateRequest CorporateRequest @relation(fields: [corporateRequestId], references: [id], onDelete: Cascade)
  selectedBid      DesignerBid?     @relation(fields: [selectedBidId], references: [id])
}

model WorkerJob {
  id          String          @id @default(uuid())
  type        String
  status      WorkerJobStatus @default(PENDING)
  payloadJson Json
  attempts    Int             @default(0)
  maxAttempts Int             @default(3)
  errorMessage String?
  nextRunAt   DateTime        @default(now())
  lastErrorAt DateTime?
  claimedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actorEmail String?
  actorRole  String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model EmailTemplate {
  id        String   @id @default(uuid())
  key       String   @unique
  subject   String
  body      String
  variables Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

enum MediaCategory {
  UI_ASSET
  BRANDING_LOGO_WEB
  BRANDING_LOGO_DASHBOARD
  BRANDING_LOGO_LOGIN
  BRANDING_LOGO_FOOTER
  BRANDING_FAVICON
  BASE_PRODUCT_IMAGE
  MOCKUP_TEMPLATE
}

enum IntakeStatus {
  NEW
  IN_REVIEW
  CONTACTED
  APPROVED
  REJECTED
  ARCHIVED
}

model MediaAsset {
  id           String        @id @default(uuid())
  key          String        @unique
  category     MediaCategory
  title        String
  description  String?
  bucket       String
  objectKey    String
  publicUrl    String?
  mimeType     String
  sizeBytes    Int
  width        Int?
  height       Int?
  uploaderId   String?
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  metadata     Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([category, isActive])
  @@index([category, sortOrder])
}

model DesignerApplication {
  id                 String       @id @default(uuid())
  firstName          String
  lastName           String
  email              String
  phoneCountryCode   String?
  phoneNumber        String?
  telegramUsername   String?
  passwordProvided   Boolean      @default(false)
  displayName        String?
  country            String?
  city               String?
  designCategories   Json?
  shortBio           String?
  portfolioFiles     Json?
  identityFiles      Json?
  selfieFiles        Json?
  confirmations      Json?
  status             IntakeStatus @default(NEW)
  reviewNotes        String?
  submittedAt        DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([status, submittedAt])
  @@index([email])
}

model ContactMessage {
  id          String       @id @default(uuid())
  firstName   String
  lastName    String?
  email       String
  phoneNumber String?
  subject     String
  message     String
  status      IntakeStatus @default(NEW)
  reviewNotes String?
  submittedAt DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status, submittedAt])
  @@index([email])
}

model CustomOrderRequest {
  id                  String       @id @default(uuid())
  fullName            String
  companyEventName    String?
  email               String
  phoneCountryCode    String?
  phoneNumber         String?
  details             String?
  estimatedBudget     String?
  preferredDelivery   String?
  productNeed         String?
  quantity            String?
  deadline            DateTime?
  hasDesign           String?
  designTypes         String?
  uploadedFiles       Json?
  status              IntakeStatus @default(NEW)
  reviewNotes         String?
  submittedAt         DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([status, submittedAt])
  @@index([email])
}
