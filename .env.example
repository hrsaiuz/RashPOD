# ─── ZeptoMail ───────────────────────────────────────────────
ZEPTO_SMTP_HOST=smtp.zeptomail.com
ZEPTO_SMTP_PORT=587
ZEPTO_SMTP_FROM=rashpod.uz
ZEPTO_SMTP_USERNAME=emailapikey
ZEPTO_SMTP_PASSWORD=__SET_IN_SECRET_MANAGER__

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=__SET_IN_SECRET_MANAGER__

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rashpod

# ─── Google Cloud ────────────────────────────────────────────
GCS_BUCKET_NAME=
GCS_BUCKET_ASSETS=
GCS_BUCKET_PUBLIC=
GCS_BUCKET_PRIVATE=
GCS_PROJECT_ID=
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
GCS_SIGNED_URL_EXPIRES_SECONDS=900

# Leave GCS project/bucket values empty for local development. The API and worker use local storage fallbacks when NODE_ENV is not production.

# ─── Queue / Worker ──────────────────────────────────────────
QUEUE_PROVIDER=local
WORKER_SECRET=local-worker-secret

# ─── Click Payment ───────────────────────────────────────────
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=__SET_IN_SECRET_MANAGER__

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
API_URL=http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:3002
WEB_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3001

# ─── Auth / JWT ──────────────────────────────────────────────
JWT_SECRET=__SET_IN_SECRET_MANAGER__
JWT_EXPIRES_IN=7d
