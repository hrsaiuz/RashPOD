# ─── ZeptoMail ───────────────────────────────────────────────
ZEPTO_SMTP_HOST=smtp.zeptomail.com
ZEPTO_SMTP_PORT=587
ZEPTO_SMTP_FROM=rashpod.uz
ZEPTO_SMTP_USERNAME=emailapikey
ZEPTO_SMTP_PASSWORD=__SET_IN_SECRET_MANAGER__

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=__SET_IN_SECRET_MANAGER__

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/rashpod

# ─── Google Cloud ────────────────────────────────────────────
GCS_BUCKET_NAME=rashpod-assets
GCS_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# ─── Click Payment ───────────────────────────────────────────
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=__SET_IN_SECRET_MANAGER__

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3002

# ─── Auth / JWT ──────────────────────────────────────────────
JWT_SECRET=__SET_IN_SECRET_MANAGER__
JWT_EXPIRES_IN=7d
